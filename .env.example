# NWO Robotics MCP Server - Environment Variables Template
# Copy this file to .env and fill in your actual values

# ============================================================================
# REQUIRED: API Key
# Get your API key from: https://nwo.capital/webapp/api-key.php
# ============================================================================
NWO_API_KEY=sk_live_your_actual_key_here

# ============================================================================
# API Endpoints Configuration
# ============================================================================

# Standard API endpoint (default: https://nwo.capital/webapp)
# Use this for full features including task planning and learning system
NWO_API_BASE=https://nwo.capital/webapp

# Edge API endpoint (default: https://nwo-robotics-api-edge.ciprianpater.workers.dev/api)
# Use this for ultra-low latency (<50ms) global inference
NWO_EDGE_API=https://nwo-robotics-api-edge.ciprianpater.workers.dev/api

# ROS2 Bridge endpoint (default: https://nwo-ros2-bridge.onrender.com)
# Cloud-based bridge for connecting to ROS2 robots
NWO_ROS2_BRIDGE=https://nwo-ros2-bridge.onrender.com

# ============================================================================
# MQTT Configuration (IoT Sensor Integration)
# ============================================================================

# MQTT Broker address (default: mqtt.nwo.capital)
MQTT_BROKER=mqtt.nwo.capital

# MQTT Broker port (default: 8883 for TLS)
MQTT_PORT=8883

# MQTT Protocol version (v3.1 or v5.0, default: v5.0)
MQTT_PROTOCOL=v5.0

# MQTT Username (optional, if your broker requires auth)
MQTT_USERNAME=

# MQTT Password (optional, if your broker requires auth)
MQTT_PASSWORD=

# Enable MQTT TLS/SSL (default: true)
MQTT_TLS_ENABLED=true

# MQTT CA Certificate path (optional, for custom certificates)
MQTT_CA_CERT=

# ============================================================================
# Logging & Debugging
# ============================================================================

# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# Enable debug mode (default: false)
DEBUG=false

# Log file path (optional, if empty logs to console)
LOG_FILE=./logs/nwo-mcp.log

# ============================================================================
# Robot & Agent Configuration
# ============================================================================

# Default robot/agent ID (used if not specified in tool calls)
DEFAULT_AGENT_ID=robot_001

# Default robot type: arm, mobile, humanoid, mobile_arm (default: mobile_arm)
DEFAULT_ROBOT_TYPE=mobile_arm

# ============================================================================
# Performance & Optimization
# ============================================================================

# Request timeout in milliseconds (default: 30000)
REQUEST_TIMEOUT_MS=30000

# Enable response caching (default: true)
ENABLE_CACHE=true

# Cache TTL in seconds (default: 3600)
CACHE_TTL_SECONDS=3600

# Max concurrent API requests (default: 10)
MAX_CONCURRENT_REQUESTS=10

# ============================================================================
# Simulation & Training (Optional)
# ============================================================================

# Default physics engine: mujoco, isaac_sim, bullet, unity_ml (default: mujoco)
PHYSICS_ENGINE=mujoco

# Default RL training algorithm: PPO, SAC, DDPG, TD3 (default: PPO)
RL_ALGORITHM=PPO

# Default simulation environment: kitchen, warehouse, office, factory (default: warehouse)
SIM_ENVIRONMENT=warehouse

# ============================================================================
# Safety & Compliance
# ============================================================================

# Enable real-time safety monitoring (default: true)
ENABLE_SAFETY_MONITORING=true

# Emergency stop response time in milliseconds (default: 10)
EMERGENCY_STOP_RESPONSE_MS=10

# Enable collision detection (default: true)
ENABLE_COLLISION_DETECTION=true

# Human proximity warning distance in meters (default: 1.5)
HUMAN_PROXIMITY_WARNING_M=1.5

# ============================================================================
# Feature Flags (Enable/Disable Features)
# ============================================================================

# Enable SLAM mapping (default: true)
ENABLE_SLAM=true

# Enable reinforcement learning features (default: true)
ENABLE_RL=true

# Enable sensor fusion (default: true)
ENABLE_SENSOR_FUSION=true

# Enable gesture recognition (default: true)
ENABLE_GESTURE_RECOGNITION=true

# Enable voice commands (default: true)
ENABLE_VOICE_COMMANDS=true

# Enable tactile sensing (ORCA Hand, default: true)
ENABLE_TACTILE_SENSING=true

# Enable task planning (default: true)
ENABLE_TASK_PLANNER=true

# Enable online learning (default: true)
ENABLE_ONLINE_LEARNING=true

# ============================================================================
# Development & Testing (NOT for Production)
# ============================================================================

# Use mock API responses for testing (default: false)
USE_MOCK_API=false

# Mock response delay in milliseconds (default: 0)
MOCK_API_DELAY_MS=0

# Enable API request logging (default: false)
LOG_API_REQUESTS=false

# ============================================================================
# Server Configuration
# ============================================================================

# Server port (default: 3000, set to 0 to use random port)
PORT=3000

# Server host (default: localhost)
HOST=localhost

# Enable CORS (default: false)
ENABLE_CORS=false

# Allowed origins for CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================================================
# External Service Integration (Optional)
# ============================================================================

# Sentry.io error tracking (optional)
SENTRY_DSN=

# Datadog monitoring (optional)
DATADOG_API_KEY=

# ============================================================================
# Notes
# ============================================================================
# 
# 1. API Key: Get from https://nwo.capital/webapp/api-key.php
#    - Free tier: 100,000 calls/month
#    - Prototype: 500,000 calls/month
#    - Production: Unlimited
#
# 2. MQTT: For IoT sensor integration
#    - Broker: mqtt.nwo.capital:8883
#    - Topics: nwo/agents/{id}/sensors, nwo/agents/{id}/commands
#    - Requires API key for authentication
#
# 3. Edge API: For ultra-low latency
#    - 200+ global edge locations
#    - <50ms response time
#    - Auto-scaling and caching
#
# 4. ROS2 Bridge: For physical robot connection
#    - Supports: UR5e, Panda, Spot, generic ROS2
#    - WebSocket and MQTT support
#    - Cloud-based (50-200ms latency) or self-hosted (<10ms)
#
# ============================================================================
